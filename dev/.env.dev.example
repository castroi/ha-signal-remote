# DEV env for the bridge in docker-compose.dev.yml.  cp to .env.dev and edit.
# These are throwaway dev values — NOT secrets. The real template is .env.example.

# Paste a Home Assistant long-lived access token here (create it in the HA UI:
# your profile → Security → Long-lived access tokens) AFTER first boot/onboarding.
HA_TOKEN=

# The bot's "number" — only used to build the mock WS receive path; any value works.
BOT_NUMBER=+15550000000

# Authorized sender(s). The dev runbook injects messages as this UUID, so it must
# match what you pass to /inject.
ALLOWLIST_UUIDS=dev-uuid-1

# Any non-empty salt for the audit log in dev.
AUDIT_SALT=dev-only-salt-not-secret

# Clock reference. In dev, point this at the mock's /time endpoint, which returns
# the container's own clock — so skew is ~0 and covers aren't disabled by a
# mismatch between this environment's system date and real-world time servers.
# (To test clock-skew safe-mode / gate 8, skew the bridge container clock or point
# this at a deliberately-wrong source.)
CLOCK_REFERENCES=http://mock-signal:8080/time
