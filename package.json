{
  "name": "home-control-bridge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Signal -> Home Assistant cover/light control bridge",
  "engines": {
    "node": ">=20 <21"
  },
  "packageManager": "pnpm@9.15.9",
