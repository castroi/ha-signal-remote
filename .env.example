# ---------------------------------------------------------------------------
# home-control-bridge — environment configuration
#
# Copy this file to `.env` and fill in real values. `.env` is gitignored;
# this `.env.example` (no secrets) is committed as the template.
#
#   cp .env.example .env
#
# Never commit real secrets. Provide them via this env file or your secrets
# manager. The bridge fails fast on startup if any REQUIRED var is missing.
# ---------------------------------------------------------------------------

# === REQUIRED ===============================================================

# Home Assistant base URL (reached over localhost / the private bridge network).
# Example: http://homeassistant:8123  or  http://127.0.0.1:8123
HA_BASE_URL=http://homeassistant:8123

# HA long-lived access token. PRIVILEGED — full user permissions, no per-entity
# scoping. Keep tight file perms, never log it, rotate if the Pi is exposed.
HA_TOKEN=

# signal-cli-rest-api base URL (bbernhard container, MODE=json-rpc).
# Example: http://signal-cli-rest-api:8080
SIGNAL_API_URL=http://signal-cli-rest-api:8080

# The bot's own dedicated Signal number (E.164), used to address signal-cli.
BOT_NUMBER=+10000000000

# Authorized senders — comma-separated Signal sourceUuids (ACI), NOT phone
# numbers (identity is pinned on UUID; the number may be empty). At least one
# is required or the bridge refuses to start. Unknown UUIDs are silently dropped.
ALLOWLIST_UUIDS=11111111-2222-3333-4444-555555555555

# Salt for the privacy-safe audit log (UUIDs are stored as a salted HMAC, never
# raw). Use a long random value; treat as a secret. Generate one with:
#   openssl rand -hex 32
AUDIT_SALT=

# === OPTIONAL ===============================================================

# Ordered list of external time references (comma-separated URLs) for the
# clock-health check. Covers are healthy while ANY one answers; if ALL are
# unreachable past the offline grace window, covers fail safe (disabled).
# Defaults to the two below if unset.
# CLOCK_REFERENCES=https://worldtimeapi.org/api/ip,https://timeapi.io/api/time/current/zone?timeZone=UTC

# Path to the alias table (rooms/lights → HA entity_ids + per-entity timeouts).
# Defaults to /app/config/aliases.yaml (matches the docker-compose mount).
# Copy config/aliases.example.yaml to config/aliases.yaml and edit it.
# ALIAS_PATH=/app/config/aliases.yaml
